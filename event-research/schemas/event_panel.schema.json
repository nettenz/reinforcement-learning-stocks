{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "event_panel",
  "type": "object",
  "required": [
    "event_id",
    "ticker",
    "event_type",
    "event_timestamp_utc",
    "market_session",
    "anchor_bar_timestamp_utc",
    "anchor_price",
    "close_t0",
    "has_price_alignment"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "ticker": { "type": "string" },
    "event_type": { "type": "string" },
    "event_timestamp_utc": { "type": "string", "format": "date-time" },
    "market_session": { "type": "string" },
    "anchor_bar_timestamp_utc": { "type": "string", "format": "date-time" },
    "anchor_price": { "type": "number" },
    "close_t0": { "type": "number" },
    "close_t1d": { "type": ["number", "null"] },
    "close_t3d": { "type": ["number", "null"] },
    "close_t5d": { "type": ["number", "null"] },
    "forward_return_1d": { "type": ["number", "null"] },
    "forward_return_3d": { "type": ["number", "null"] },
    "forward_return_5d": { "type": ["number", "null"] },
    "benchmark_return_1d": { "type": ["number", "null"] },
    "benchmark_return_3d": { "type": ["number", "null"] },
    "benchmark_return_5d": { "type": ["number", "null"] },
    "excess_return_1d": { "type": ["number", "null"] },
    "excess_return_3d": { "type": ["number", "null"] },
    "excess_return_5d": { "type": ["number", "null"] },
    "sentiment_score": { "type": ["number", "null"] },
    "sentiment_label": { "type": ["string", "null"] },
    "event_window_pre_minutes": { "type": "integer" },
    "event_window_post_minutes": { "type": "integer" },
    "has_price_alignment": { "type": "boolean" },
    "has_label_1d": { "type": "boolean" },
    "has_label_3d": { "type": "boolean" },
    "has_label_5d": { "type": "boolean" }
  }
}
